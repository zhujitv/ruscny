# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=false

# PostgreSQL / Redis
DATABASE_URL=postgresql://translator:translator@localhost:5432/translator?schema=public
REDIS_URL=redis://localhost:6379
RATE_LIMIT_NAMESPACE=zh-ru-translator-development-rate-limit-
# Production must use PostgreSQL sslmode=require/verify-* and rediss://.

# Authentication. Generate long, independent random values outside source control.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
PASSWORD_PEPPER=
# Root encryption key for credentials maintained in the administrator console.
# This bootstrap key itself must remain in the deployment secret store.
SERVICE_CONFIG_MASTER_KEY=
SERVICE_CONFIG_PREVIOUS_MASTER_KEYS=
# Extra exact hostnames allowed for administrator-managed HTTPS/WSS endpoints.
SERVICE_CONFIG_ALLOWED_HOSTS=
# Initial server-console bootstrap. Comma-separated immutable User ids of
# already registered ACTIVE accounts; keep the list in Secret Manager.
# After setting User.isSystemAdmin through a controlled operation, this may be
# emptied. The unified USER account and per-meeting HOST role do not grant
# server-console access.
SYSTEM_ADMIN_USER_IDS=
ADMIN_PASSWORD_RESET_TTL_MINUTES=30
LEGAL_POLICY_VERSION=2026-07-19-ai-summary

# Translation provider: mock is for local development only; aliyun enables production adapters.
TRANSLATION_PROVIDER=mock
ALIYUN_API_KEY=
# Use the region/workspace-compatible endpoints and an API Key scoped by the provider console.
ALIYUN_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_ASR_MODEL=qwen3-asr-flash
ALIYUN_TRANSLATION_MODEL=qwen-mt-flash
ALIYUN_TTS_MODEL=qwen3-tts-flash
# AI meeting minutes use the same server-side Bailian API Key. Keep mock only
# for local development; production must use aliyun.
SUMMARY_PROVIDER=mock
ALIYUN_SUMMARY_MODEL=qwen-plus
SUMMARY_MAX_MESSAGES=1000
SUMMARY_MAX_INPUT_CHARACTERS=500000
SUMMARY_REQUEST_TIMEOUT_MS=120000
SUMMARY_GENERATION_STALE_MS=180000
ALIYUN_TTS_VOICE_ZH=
ALIYUN_TTS_VOICE_RU=
ALIYUN_REQUEST_TIMEOUT_MS=30000
# RTC 3.0 credentials may be entered in the administrator console. Environment
# values are a migration fallback and must never be compiled into the app.
ALIYUN_RTC_APP_ID=
ALIYUN_RTC_APP_KEY=
ALIYUN_RTC_TOKEN_TTL_SECONDS=3600
# Server-side realtime translation relay configuration (never sent to mobile).
ALIYUN_REALTIME_WORKSPACE_ID=
ALIYUN_REALTIME_API_KEY=
ALIYUN_REALTIME_TRANSLATION_ENABLED=false
ALIYUN_REALTIME_WEBSOCKET_URL=wss://cn-beijing.maas.aliyuncs.com/api-ws/v1/realtime
ALIYUN_REALTIME_TRANSLATION_MODEL=qwen3.5-livetranslate-flash-realtime
ALIYUN_REALTIME_MAX_SESSION_SECONDS=3600
# Reserved only for a future legacy/classic TTS adapter. The current Qwen3-TTS
# provider uses ALIYUN_API_KEY and does not read these values.
ALIYUN_TTS_APP_KEY=
ALIYUN_TTS_TOKEN=

# Transactional email. Local tests use mock. Production uses Resend with a
# verified sending domain; a dedicated subdomain such as send.ruscny.net is
# recommended so website and mail reputation stay isolated.
EMAIL_PROVIDER=mock
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
EMAIL_FROM=RUSCNY Meeting Minutes <minutes@send.ruscny.net>
EMAIL_REPLY_TO=
EMAIL_REQUEST_TIMEOUT_MS=15000
EMAIL_VERIFICATION_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=30

# Mobile release identifiers and optional push placeholders. Push is not on
# the first-version real-time path; do not fill these unless that adapter is enabled.
ANDROID_PACKAGE_NAME=com.tooyei.translator
IOS_BUNDLE_ID=com.tooyei.translator
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=

# Public links. Production uses the same HTTPS origin for the website, API,
# Socket.IO, downloads, admin console and invitation links.
PUBLIC_APP_URL=https://www.ruscny.net
# Local development remains localhost. Production must override this with
# https://www.ruscny.net.
PUBLIC_API_URL=http://localhost:3000
INVITE_TTL_MINUTES=1440
# Qwen3-ASR receives Base64 inside JSON, so the server enforces an exact 6 MB
# binary ceiling below the upstream 10 MB request limit.
UPLOAD_MAX_BYTES=6000000
CORS_ORIGINS=

# Audio and object storage. Local storage is suitable only for development.
AUDIO_STORAGE_DRIVER=local
AUDIO_LOCAL_DIRECTORY=storage/audio
AUDIO_URL_SIGNING_SECRET=
AUDIO_SIGNED_URL_TTL_SECONDS=900
# Durable deletion worker: failed object deletions are retried after the
# corresponding account or conversation database deletion commits.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Alibaba Cloud OSS requires virtual-hosted style (false). Set true only for a
# compatible local service such as MinIO that explicitly requires path style.
S3_FORCE_PATH_STYLE=false
